{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including progress and stats.",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "The warrior's name." },
        "avatarId": { "type": "string", "description": "Selected avatar ID." },
        "currentDay": { "type": "integer", "description": "Current day in the week (1-7)." },
        "week": { "type": "integer", "description": "Current week number." },
        "streak": { "type": "integer", "description": "Current daily streak." },
        "xp": { "type": "integer", "description": "Total experience points." },
        "completedDays": { "type": "array", "items": { "type": "integer" }, "description": "List of completed days in the current week." },
        "lastCompletedDate": { "type": "string", "description": "ISO date string of the last completion." },
        "totalDaysCompleted": { "type": "integer", "description": "Total days completed across all weeks." },
        "totalDojoWins": { "type": "integer", "description": "Total wins in Dojo mode." },
        "longestStreak": { "type": "integer", "description": "The highest streak achieved." }
      },
      "required": ["username", "avatarId", "currentDay", "week", "streak", "xp", "completedDays"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    }
  }
}
